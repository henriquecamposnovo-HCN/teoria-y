[package]
name = "contract_y"
version = "0.1.0"
description = "Contract Y -- Smart contracts universais via Superposicao de Papeis"
edition = "2021"

[lib]
crate-type = ["cdylib", "lib"]
name = "contract_y"

[features]
no-entrypoint = []
no-idl = []
no-log-ix-name = []
cpi = ["no-entrypoint"]
default = []

[dependencies]
anchor-lang = "0.29.0"
